<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Homepage</title>
</head>
<body>
 <h1>Car Inventory</h1>
  <a href="/cars/new">Add a New Car</a>
  <hr>

  <% allData.forEach(car => { %>
  <div style="border:1px solid #ccc; padding:10px; margin:10px;">
    
    <h3><%= car.modelName %> (<%= car.year %>)</h3>
    <p><strong>Category:</strong> <%= car.category %></p>

    <!-- Edit -->
    <a href="/cars/<%= car._id %>">Edit</a>

    <!-- Delete -->
    <form action="/cars/<%= car._id %>?_method=DELETE" method="POST" style="display:inline;">
      <button onclick="return confirm('Delete this car?')">Delete</button>
    </form>

  </div>
<% }) %>
        
</body>
</html>